# Deploy configuration for ./deploy/deploy.sh — copy to `.env` and `source .env`
# before deploying. None of these are secrets, but keep your real `.env` untracked
# (it's gitignored). The app itself needs no env to run locally; only deploying does.

# Your domain (a TLS cert for it must already exist on the VM — see deploy/setup-vm.sh).
export DOMAIN=str.example.com

# Space-separated list of client IPs allowed to reach the app over HTTPS
# (e.g. your home and/or phone's public IP). nginx denies everyone else.
export ALLOW_IPS="203.0.113.7"

# The VM's public IP or hostname. An AWS Elastic IP is convenient (stable across reboots).
export SSH_HOST=203.0.113.10
export SSH_USER=ec2-user
export SSH_KEY=$HOME/.ssh/id_ed25519

# Used only by deploy/setup-vm.sh (one-time TLS cert issuance):
export EMAIL=you@example.com
